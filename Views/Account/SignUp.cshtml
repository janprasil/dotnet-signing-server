@model DotNetSigningServer.Models.SignUpViewModel
@inject Microsoft.Extensions.Localization.IStringLocalizer<DotNetSigningServer.Resources.SharedStrings> L
@{
    ViewData["Title"] = L["SignUpLinkText"].Value;
}
<h1>@L["CreateAccountHeading"]</h1>

@if (TempData["Error"] != null)
{
    <div class="flash error">@TempData["Error"]</div>
}
@if (TempData["Info"] != null)
{
    <div class="flash info">@TempData["Info"]</div>
}
<form method="post" class="auth-form">
    @Html.AntiForgeryToken()
    <div class="form-group">
        <label asp-for="Email" class="form-label">@L["EmailLabel"]</label>
        <input asp-for="Email" class="form-input" />
        <span asp-validation-for="Email" class="form-validation"></span>
    </div>
    <div class="form-group">
        <label asp-for="Password" class="form-label">@L["PasswordLabel"]</label>
        <input asp-for="Password" type="password" class="form-input" />
        <span asp-validation-for="Password" class="form-validation"></span>
    </div>
    <div class="form-group">
        <label asp-for="ConfirmPassword" class="form-label">@L["ConfirmPasswordLabel"]</label>
        <input asp-for="ConfirmPassword" type="password" class="form-input" />
        <span asp-validation-for="ConfirmPassword" class="form-validation"></span>
    </div>

    <label class="form-check">
        <input type="checkbox" name="acceptPolicies" required />
        <span>@Html.Raw(string.Format(L["SignUpAgreeTerms"].Value,
            $"<a href='/Legal/TermsOfService' target='_blank'>{L["TermsOfServiceLink"].Value}</a>",
            $"<a href='/Legal/PrivacyPolicy' target='_blank'>{L["PrivacyPolicyLink"].Value}</a>"))</span>
    </label>

    <button type="submit" class="btn btn-primary">@L["SignUpButton"]</button>
</form>

<p class="muted text-center mt-3">@L["AlreadyHaveAccount"] <a href="/Account/SignIn">@L["SignInLinkText"]</a>.</p>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
