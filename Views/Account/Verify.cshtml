@inject Microsoft.Extensions.Localization.IStringLocalizer<DotNetSigningServer.Resources.SharedStrings> L
@{
    ViewData["Title"] = L["VerifyEmailTitle"].Value;
}

<h1>@L["VerifyEmailHeading"]</h1>

@{
    var verified = ViewData["Verified"] as bool? ?? false;
}

<p class="text-small">
    @L["VerificationLinkSent"]
    @if (TempData["Error"] != null)
    {
    <div class="flash error">@TempData["Error"]</div>
}
@if (TempData["Info"] != null)
{
    <div class="flash info">@TempData["Info"]</div>
}
@if (verified)
{
    <div class="flash info" style="display:inline-block;margin-left:0.5rem;">@L["VerifyEmailConfirmedMsg"]</div>
}
</p>
