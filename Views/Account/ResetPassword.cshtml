@model DotNetSigningServer.Models.ResetPasswordViewModel
@inject Microsoft.Extensions.Localization.IStringLocalizer<DotNetSigningServer.Resources.SharedStrings> L
@{
    ViewData["Title"] = L["ResetPasswordTitle"].Value;
}
<h1 class="content-box-title">@L["ResetPasswordHeading"]</h1>

@if (TempData["Error"] != null)
{
    <div class="flash error">@TempData["Error"]</div>
}
@if (TempData["Info"] != null)
{
    <div class="flash info">@TempData["Info"]</div>
}
@if (!ViewData.ModelState.IsValid)
{
    <div class="flash error">
        @Html.ValidationSummary(excludePropertyErrors: true, message: L["CorrectErrorsBelow"].Value)
    </div>
}

<form method="post" class="auth-form">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="Token" />

    <div class="form-group">
        <label asp-for="Password" class="form-label">@L["NewPasswordLabel"]</label>
        <input asp-for="Password" type="password" class="form-input" />
        <span asp-validation-for="Password" class="form-validation"></span>
    </div>

    <div class="form-group">
        <label asp-for="ConfirmPassword" class="form-label">@L["ConfirmNewPasswordLabel"]</label>
        <input asp-for="ConfirmPassword" type="password" class="form-input" />
        <span asp-validation-for="ConfirmPassword" class="form-validation"></span>
    </div>

    <button type="submit" class="btn btn-primary">@L["ResetPasswordButton"]</button>
</form>

<p class="muted mt-3 text-center">@L["RememberPasswordQ"] <a href="/Account/SignIn">@L["SignInLinkText"]</a>.</p>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
