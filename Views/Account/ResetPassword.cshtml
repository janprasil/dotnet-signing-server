@model DotNetSigningServer.Models.ResetPasswordViewModel
@{
    ViewData["Title"] = "Reset password";
}
<h1 class="content-box-title">Reset Password</h1>

@if (TempData["Error"] != null)
{
    <div class="flash error">@TempData["Error"]</div>
}
@if (TempData["Info"] != null)
{
    <div class="flash info">@TempData["Info"]</div>
}
@if (!ViewData.ModelState.IsValid)
{
    <div class="flash error">
        @Html.ValidationSummary(excludePropertyErrors: true, message: "Please correct the errors below.")
    </div>
}

<form method="post" class="auth-form">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="Token" />

    <div class="form-group">
        <label asp-for="Password" class="form-label">New password</label>
        <input asp-for="Password" type="password" class="form-input" />
        <span asp-validation-for="Password" class="form-validation"></span>
    </div>

    <div class="form-group">
        <label asp-for="ConfirmPassword" class="form-label">Confirm new password</label>
        <input asp-for="ConfirmPassword" type="password" class="form-input" />
        <span asp-validation-for="ConfirmPassword" class="form-validation"></span>
    </div>

    <button type="submit" class="btn btn-primary">Reset password</button>
</form>

<p class="muted mt-3 text-center">Remember your password? <a href="/Account/SignIn">Sign in</a>.</p>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
