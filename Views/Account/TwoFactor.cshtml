@inject Microsoft.Extensions.Localization.IStringLocalizer<DotNetSigningServer.Resources.SharedStrings> L
@{
    ViewData["Title"] = L["TwoFactorTitle"].Value;
    var email = ViewData["Email"]?.ToString() ?? string.Empty;
    var rememberMe = (ViewData["RememberMe"] as bool?) ?? false;
}

<h1>@L["TwoFactorHeading"]</h1>

<div class="auth-card">
    @if (TempData["Error"] != null)
    {
        <div class="flash error">@TempData["Error"]</div>
    }
    @if (TempData["Info"] != null)
    {
        <div class="flash info">@TempData["Info"]</div>
    }

    <p class="muted">@string.Format(L["TwoFactorCodeSentMsgFmt"].Value, email)</p>

    <form method="post" action="/Account/TwoFactor" class="auth-form">
        @Html.AntiForgeryToken()
        <input type="hidden" name="email" value="@email" />
        <input type="hidden" name="rememberMe" value="@rememberMe" />
        <div class="form-group">
            <label for="code" class="form-label">@L["SixDigitCodeLabel"]</label>
            <input id="code" class="form-input" type="text" name="code" maxlength="6" minlength="6" pattern="\d{6}"
                required />
        </div>
        <button type="submit" class="btn btn-primary full-w mt-3">@L["VerifyButton"]</button>
    </form>
</div>
