@model DotNetSigningServer.Models.SignInViewModel
@inject Microsoft.Extensions.Localization.IStringLocalizer<DotNetSigningServer.Resources.SharedStrings> L
@{
    ViewData["Title"] = L["SignInTitle"].Value;
    var returnUrl = ViewData["ReturnUrl"] as string;
}
<h1 class="content-box-title">@L["SignInHeading"]</h1>

@if (TempData["Error"] != null)
{
    <div class="flash error">@TempData["Error"]</div>
}
@if (TempData["Info"] != null)
{
    <div class="flash info">@TempData["Info"]</div>
}
@if (!ViewData.ModelState.IsValid)
{
    <div class="flash error">
        @Html.ValidationSummary(excludePropertyErrors: true, message: L["SignInFailedMsg"].Value)
    </div>
}
<form method="post" class="auth-form">
    @Html.AntiForgeryToken()
    <input type="hidden" name="returnUrl" value="@returnUrl" />
    <div class="form-group">
        <label asp-for="Email" class="form-label">@L["EmailLabel"]</label>
        <input asp-for="Email" class="form-input" />
        <span asp-validation-for="Email" class="form-validation"></span>
    </div>

    <div class="form-group">
        <label asp-for="Password" class="form-label">@L["PasswordLabel"]</label>
        <input asp-for="Password" type="password" class="form-input" />
        <span asp-validation-for="Password" class="form-validation"></span>
    </div>

    <div class="form-group" style="display:flex;justify-content:space-between;align-items:center;">
        <label class="form-check" style="margin:0;">
            <input asp-for="RememberMe" type="checkbox" /> @L["SignInRememberMe"]
        </label>
        <a href="/Account/ForgotPassword" class="text-small">@L["SignInForgotPassword"]</a>
    </div>

    <button type="submit" class="btn btn-primary">@L["SignInButton"]</button>
</form>

<p class="muted mt-3 text-center">@L["SignInNoAccount"] <a href="/Account/SignUp">@L["SignUpLinkText"]</a>.</p>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
