@model DotNetSigningServer.Models.ChangePasswordViewModel
@inject Microsoft.Extensions.Localization.IStringLocalizer<DotNetSigningServer.Resources.SharedStrings> L
@{
    ViewData["Title"] = L["ChangePasswordTitle"].Value;
}
<h1 class="content-box-title">@L["ChangePasswordHeading"]</h1>

@if (TempData["Error"] != null)
{
    <div class="flash error">@TempData["Error"]</div>
}
@if (TempData["Info"] != null)
{
    <div class="flash info">@TempData["Info"]</div>
}
@if (!ViewData.ModelState.IsValid)
{
    <div class="flash error">
        @Html.ValidationSummary(excludePropertyErrors: true, message: L["CorrectErrorsBelow"].Value)
    </div>
}

<form method="post" class="auth-form">
    @Html.AntiForgeryToken()

    <div class="form-group">
        <label asp-for="CurrentPassword" class="form-label">@L["CurrentPasswordLabel"]</label>
        <input asp-for="CurrentPassword" type="password" class="form-input" autocomplete="current-password" />
        <span asp-validation-for="CurrentPassword" class="form-validation"></span>
    </div>

    <div class="form-group">
        <label asp-for="NewPassword" class="form-label">@L["NewPasswordLabel"]</label>
        <input asp-for="NewPassword" type="password" class="form-input" autocomplete="new-password" />
        <span asp-validation-for="NewPassword" class="form-validation"></span>
    </div>

    <div class="form-group">
        <label asp-for="ConfirmPassword" class="form-label">@L["ConfirmNewPasswordLabel"]</label>
        <input asp-for="ConfirmPassword" type="password" class="form-input" autocomplete="new-password" />
        <span asp-validation-for="ConfirmPassword" class="form-validation"></span>
    </div>

    <button type="submit" class="btn btn-primary">@L["ChangePasswordButton"]</button>
    <a href="/Account" class="btn btn-secondary">@L["Cancel"]</a>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
