@model DotNetSigningServer.Models.ForgotPasswordViewModel
@inject Microsoft.Extensions.Localization.IStringLocalizer<DotNetSigningServer.Resources.SharedStrings> L
@{
    ViewData["Title"] = L["ForgotPasswordTitle"].Value;
}
<h1 class="content-box-title">@L["ForgotPasswordHeading"]</h1>

@if (TempData["Error"] != null)
{
    <div class="flash error">@TempData["Error"]</div>
}
@if (TempData["Info"] != null)
{
    <div class="flash info">@TempData["Info"]</div>
}
@if (!ViewData.ModelState.IsValid)
{
    <div class="flash error">
        @Html.ValidationSummary(excludePropertyErrors: true)
    </div>
}

<p class="muted">@L["ForgotPasswordHint"]</p>

<form method="post" class="auth-form">
    @Html.AntiForgeryToken()
    <div class="form-group">
        <label asp-for="Email" class="form-label">@L["EmailLabel"]</label>
        <input asp-for="Email" class="form-input" />
        <span asp-validation-for="Email" class="form-validation"></span>
    </div>

    <button type="submit" class="btn btn-primary">@L["SendResetLink"]</button>
</form>

<p class="muted mt-3 text-center">@L["RememberPasswordQ"] <a href="/Account/SignIn">@L["SignInLinkText"]</a>.</p>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
