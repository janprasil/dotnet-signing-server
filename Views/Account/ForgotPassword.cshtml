@model DotNetSigningServer.Models.ForgotPasswordViewModel
@{
    ViewData["Title"] = "Forgot password";
}
<h1 class="content-box-title">Forgot Password</h1>

@if (TempData["Error"] != null)
{
    <div class="flash error">@TempData["Error"]</div>
}
@if (TempData["Info"] != null)
{
    <div class="flash info">@TempData["Info"]</div>
}
@if (!ViewData.ModelState.IsValid)
{
    <div class="flash error">
        @Html.ValidationSummary(excludePropertyErrors: true)
    </div>
}

<p class="muted">Enter your email address and we'll send you a link to reset your password.</p>

<form method="post" class="auth-form">
    @Html.AntiForgeryToken()
    <div class="form-group">
        <label asp-for="Email" class="form-label">Email</label>
        <input asp-for="Email" class="form-input" />
        <span asp-validation-for="Email" class="form-validation"></span>
    </div>

    <button type="submit" class="btn btn-primary">Send reset link</button>
</form>

<p class="muted mt-3 text-center">Remember your password? <a href="/Account/SignIn">Sign in</a>.</p>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
