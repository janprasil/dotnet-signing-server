@{
    ViewData["Title"] = "Support";
}
<h1>Support</h1>
<p class="muted mt-2 mb-3">Submit a support ticket and our team will get back to you.</p>

@if (TempData["Info"] is string info)
{
    <div class="flash-info">@info</div>
}
@if (TempData["Error"] is string error)
{
    <div class="flash-error">@error</div>
}

<div class="card">
    <h2>Submit a Ticket</h2>
    <form method="post" action="/support/ticket">
        @Html.AntiForgeryToken()

        <div class="form-group">
            <label for="category">Category</label>
            <select name="category" id="category" required>
                <option value="signing">Signing Issues</option>
                <option value="templates">Templates</option>
                <option value="billing">Billing &amp; Subscription</option>
                <option value="account">Account &amp; Access</option>
                <option value="other" selected>Other</option>
            </select>
        </div>

        <div class="form-group">
            <label for="priority">Priority</label>
            <select name="priority" id="priority">
                <option value="low">Low</option>
                <option value="normal" selected>Normal</option>
                <option value="high">High</option>
            </select>
        </div>

        <div class="form-group">
            <label for="subject">Subject</label>
            <input type="text" name="subject" id="subject" placeholder="Brief description of your issue" required />
        </div>

        <div class="form-group">
            <label for="message">Message</label>
            <textarea name="message" id="message" rows="6" placeholder="Describe the issue in detail." required></textarea>
        </div>

        <button type="submit" class="btn btn-primary">Submit Ticket</button>
    </form>
</div>

<div class="card mt-3">
    <h2>Contact</h2>
    <p><strong>Email:</strong> <a href="mailto:support@performance4.cz">support@performance4.cz</a></p>
    <p><strong>Company:</strong> Performance4 s.r.o.</p>
</div>
