@inject Microsoft.Extensions.Localization.IStringLocalizer<DotNetSigningServer.Resources.SharedStrings> L
@{
    ViewData["Title"] = L["SupportTitle"].Value;
}
<h1>@L["SupportTitle"]</h1>
<p class="muted mt-2 mb-3">@L["SupportDesc"]</p>

@if (TempData["Info"] is string info)
{
    <div class="flash-info">@info</div>
}
@if (TempData["Error"] is string error)
{
    <div class="flash-error">@error</div>
}

<div class="card">
    <h2>@L["SupportSubmitTicketTitle"]</h2>
    <form method="post" action="/support/ticket">
        @Html.AntiForgeryToken()

        <div class="form-group">
            <label for="category">@L["SupportCategory"]</label>
            <select name="category" id="category" required>
                <option value="signing">@L["SupportCategorySigning"]</option>
                <option value="templates">@L["SupportCategoryTemplates"]</option>
                <option value="billing">@L["SupportCategoryBilling"]</option>
                <option value="account">@L["SupportCategoryAccount"]</option>
                <option value="other" selected>@L["SupportCategoryOther"]</option>
            </select>
        </div>

        <div class="form-group">
            <label for="priority">@L["SupportPriority"]</label>
            <select name="priority" id="priority">
                <option value="low">@L["SupportPriorityLow"]</option>
                <option value="normal" selected>@L["SupportPriorityNormal"]</option>
                <option value="high">@L["SupportPriorityHigh"]</option>
            </select>
        </div>

        <div class="form-group">
            <label for="subject">@L["SupportSubjectLabel"]</label>
            <input type="text" name="subject" id="subject" placeholder="@L["SupportSubjectPlaceholder"]" required />
        </div>

        <div class="form-group">
            <label for="message">@L["SupportMessageLabel"]</label>
            <textarea name="message" id="message" rows="6" placeholder="@L["SupportMessagePlaceholder"]" required></textarea>
        </div>

        <button type="submit" class="btn btn-primary">@L["SupportSubmitButton"]</button>
    </form>
</div>

<div class="card mt-3">
    <h2>@L["SupportContactTitle"]</h2>
    <p><strong>@L["SupportEmailLabel"]</strong> <a href="mailto:support@performance4.cz">support@performance4.cz</a></p>
    <p><strong>@L["SupportCompanyLabel"]</strong> Performance4 s.r.o.</p>
</div>
