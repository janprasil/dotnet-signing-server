@model DotNetSigningServer.Controllers.RequestsController.RequestsViewModel
@inject Microsoft.Extensions.Localization.IStringLocalizer<DotNetSigningServer.Resources.SharedStrings> L
@{
    ViewData["Title"] = L["RequestsTitle"].Value;

    string FilterUrl(string filter) => Url.Action("Index", "Requests", new { filter, page = 1 }) ?? "/Requests";
    string PageUrl(int page) => Url.Action("Index", "Requests", new { filter = Model.Filter, page }) ?? "/Requests";

    string FilterLabel(string f) => f switch
    {
        "success" => L["RequestsFilterSuccess"].Value,
        "error" => L["RequestsFilterErrors"].Value,
        _ => L["RequestsFilterAll"].Value,
    };

    int firstShown = Model.TotalCount == 0 ? 0 : (Model.Page - 1) * Model.PageSize + 1;
    int lastShown = Math.Min(Model.Page * Model.PageSize, Model.TotalCount);
}

<h1 class="content-box-title">@L["RequestsTitle"]</h1>
<p class="muted" style="margin-top:-0.25rem;margin-bottom:1.25rem">@L["RequestsSubtitle"]</p>

<div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(170px,1fr));gap:0.75rem;margin-bottom:1.25rem">
    <div style="padding:0.85rem;border:1px solid var(--color-card-border,#e5e7eb);border-radius:6px">
        <p class="muted" style="font-size:0.8rem;margin:0 0 0.25rem">@L["RequestsCreditsRemaining"]</p>
        <p style="font-size:1.5rem;font-weight:600;margin:0">@Model.CreditsRemaining</p>
    </div>
    <div style="padding:0.85rem;border:1px solid var(--color-card-border,#e5e7eb);border-radius:6px">
        <p class="muted" style="font-size:0.8rem;margin:0 0 0.25rem">@L["RequestsSuccess30d"]</p>
        <p style="font-size:1.5rem;font-weight:600;margin:0">@Model.SuccessCount30d</p>
    </div>
    <div style="padding:0.85rem;border:1px solid var(--color-card-border,#e5e7eb);border-radius:6px">
        <p class="muted" style="font-size:0.8rem;margin:0 0 0.25rem">@L["RequestsCreditsSpent30d"]</p>
        <p style="font-size:1.5rem;font-weight:600;margin:0">@Model.CreditsSpent30d</p>
    </div>
    <div style="padding:0.85rem;border:1px solid var(--color-card-border,#e5e7eb);border-radius:6px">
        <p class="muted" style="font-size:0.8rem;margin:0 0 0.25rem">@L["RequestsErrors30d"]</p>
        <p style="font-size:1.5rem;font-weight:600;margin:0;color:@(Model.ErrorCount30d > 0 ? "#dc2626" : "inherit")">@Model.ErrorCount30d</p>
    </div>
</div>

<div style="display:flex;gap:0.5rem;margin-bottom:1rem;flex-wrap:wrap">
    @foreach (var f in new[] { "all", "success", "error" })
    {
        var isActive = Model.Filter == f;
        <a href="@FilterUrl(f)"
           class="btn-small @(isActive ? "btn-primary" : "btn-secondary")"
           style="text-decoration:none">@FilterLabel(f)</a>
    }
</div>

<div class="table-wrapper">
    @if (Model.Rows.Count == 0)
    {
        <p class="muted m-4">@L["RequestsEmpty"]</p>
    }
    else
    {
        <table class="table">
            <thead>
                <tr>
                    <th>@L["RequestsColTime"]</th>
                    <th>@L["RequestsColOperation"]</th>
                    <th>@L["RequestsColStatus"]</th>
                    <th style="text-align:right">@L["RequestsColCredits"]</th>
                    <th style="text-align:right">@L["RequestsColDuration"]</th>
                    <th>@L["RequestsColDetails"]</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var row in Model.Rows)
                {
                    var isError = row.Status == DotNetSigningServer.Models.UsageRecordStatus.Error;
                    <tr>
                        <td>
                            <span title="@row.CreatedAt.ToString("u")">
                                @row.CreatedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss")
                            </span>
                        </td>
                        <td>
                            <code style="font-size:0.85rem">@(row.Operation ?? "-")</code>
                        </td>
                        <td>
                            @if (isError)
                            {
                                <span style="display:inline-flex;align-items:center;gap:0.35rem;padding:0.15rem 0.5rem;border-radius:999px;background:#fee2e2;color:#991b1b;font-size:0.8rem;font-weight:500">
                                    <span style="display:inline-block;width:6px;height:6px;border-radius:50%;background:#dc2626"></span>
                                    @L["RequestsStatusError"]@(row.HttpStatusCode.HasValue ? $" ({row.HttpStatusCode})" : "")
                                </span>
                            }
                            else
                            {
                                <span style="display:inline-flex;align-items:center;gap:0.35rem;padding:0.15rem 0.5rem;border-radius:999px;background:#dcfce7;color:#166534;font-size:0.8rem;font-weight:500">
                                    <span style="display:inline-block;width:6px;height:6px;border-radius:50%;background:#16a34a"></span>
                                    @L["RequestsStatusSuccess"]
                                </span>
                            }
                        </td>
                        <td style="text-align:right">
                            @if (isError)
                            {
                                <span class="muted">—</span>
                            }
                            else
                            {
                                <span title="@string.Format(L["RequestsCreditsTooltip"].Value, row.BaseCost, row.Tier)">@row.Credits</span>
                            }
                        </td>
                        <td style="text-align:right">
                            @(row.DurationMs.HasValue ? $"{row.DurationMs} ms" : "—")
                        </td>
                        <td>
                            @if (isError)
                            {
                                <code style="font-size:0.8rem">@row.ErrorCode</code>
                                @if (!string.IsNullOrWhiteSpace(row.ErrorMessage))
                                {
                                    <span class="muted" style="font-size:0.85rem">— @row.ErrorMessage</span>
                                }
                            }
                            else
                            {
                                <span class="muted">—</span>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>

@if (Model.TotalCount > 0)
{
    <div style="display:flex;align-items:center;justify-content:space-between;margin-top:1rem;flex-wrap:wrap;gap:0.5rem">
        <p class="muted" style="font-size:0.875rem;margin:0">
            @string.Format(L["RequestsPaginationLabel"].Value, firstShown, lastShown, Model.TotalCount)
        </p>
        <div style="display:flex;gap:0.5rem">
            @if (Model.HasPrevious)
            {
                <a class="btn-small btn-secondary" href="@PageUrl(Model.Page - 1)">@L["RequestsPaginationPrev"]</a>
            }
            else
            {
                <span class="btn-small btn-secondary" style="opacity:0.5;pointer-events:none">@L["RequestsPaginationPrev"]</span>
            }
            @if (Model.HasNext)
            {
                <a class="btn-small btn-secondary" href="@PageUrl(Model.Page + 1)">@L["RequestsPaginationNext"]</a>
            }
            else
            {
                <span class="btn-small btn-secondary" style="opacity:0.5;pointer-events:none">@L["RequestsPaginationNext"]</span>
            }
        </div>
    </div>
}

<p class="muted" style="font-size:0.8rem;margin-top:1.5rem">@L["RequestsPrivacyNote"]</p>
