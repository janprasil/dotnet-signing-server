@inject Microsoft.Extensions.Localization.IStringLocalizer<DotNetSigningServer.Resources.SharedStrings> L
@{
    ViewData["Title"] = L["PricingTitle"].Value;
}

<h1>@L["PricingTitle"]</h1>
<p class="muted">@L["PricingDesc"]</p>

<div class="pricing-grid">
    <div class="pricing-card">
        <div class="flex flex-col">
            <h2 class="pricing-title">@L["PricingFreeTitle"]</h2>
            <p class="muted pricing-description">@L["PricingFreeDesc"]</p>
            <p class="pricing-price">0 EUR</p>
            <p class="muted pricing-note">@L["PricingFreeNote"]</p>
            <ul class="list list-none-style">
                <li>@L["PricingFreeFeature1"]</li>
                <li>@L["PricingFreeFeature2"]</li>
            </ul>
        </div>
        <a href="/Account/SignUp" class="btn btn-primary">@L["PricingGetStarted"]</a>
    </div>

    <div class="pricing-card pricing-card--highlight">
        <div class="flex flex-col">
            <h2 class="pricing-title">@L["PricingPaidTitle"]</h2>
            <p class="muted pricing-description">@L["PricingPaidDesc"]</p>
            <p class="pricing-price">5 EUR<span style="font-size:1rem;font-weight:600;"></span>
            </p>
            <p class="muted pricing-note">@L["PricingPaidNote"]</p>
            <ul class="list list-none-style">
                <li>@L["PricingPaidFeature1"]</li>
                <li>@L["PricingPaidFeature2"]</li>
                <li>@L["PricingPaidFeature3"]</li>
            </ul>
        </div>
        <a href="/Account/SignUp" class="btn btn-primary">@L["PricingGetStarted"]</a>
    </div>
</div>
